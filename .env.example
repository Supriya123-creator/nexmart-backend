# ─── NEXMART Backend Environment Variables ───────────────────────────────────
# NEVER commit this file to GitHub — it is in .gitignore

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers → copy URI
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/nexmart?retryWrites=true&w=majority

# JWT secret — use any long random string (keep it secret!)
JWT_SECRET=nexmart_super_secret_jwt_key_change_this_in_production_2025

# Server port
PORT=5000

# Your Netlify frontend URL (for CORS whitelist)
# e.g. https://my-nexmart.netlify.app
# During local dev, http://localhost is also allowed automatically
FRONTEND_URL=https://your-nexmart.netlify.app
